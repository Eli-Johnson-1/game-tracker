# ─── Required ────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Use a long random string (e.g. openssl rand -hex 32).
JWT_SECRET=changeme_use_a_long_random_string_here

# Microsoft Entra ID (Azure AD) app registration credentials.
# Create an app registration at https://entra.microsoft.com and copy the values below.
ENTRA_TENANT_ID=your-tenant-id
ENTRA_CLIENT_ID=your-client-id

# ─── Optional ─────────────────────────────────────────────────────────────────

# Anthropic API key for Terraforming Mars board photo analysis.
# Leave blank to disable the feature.
ANTHROPIC_API_KEY=

# Username granted admin rights (delete/edit any game regardless of participation).
# Must exactly match the Entra display name of the intended admin user.
ADMIN_USERNAME=
